BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//GitHub Copilot//Indoor Plants Watering Calendar//FI
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:Sisäkasvien kastelukalenteri
X-WR-TIMEZONE:Europe/Helsinki

BEGIN:VEVENT
UID:rahapuu-kevat-kesa-1@sisakasvien-kastelukalenteri
DTSTAMP:20260503T090000Z
DTSTART;VALUE=DATE:20260401
RRULE:FREQ=WEEKLY;INTERVAL=2;BYMONTH=4,5,6,7,8,9
SUMMARY:Rahapuu (Crassula ovata) - kastelun tarkistus
DESCRIPTION:Tarkista kastelutarve kahden viikon välein 
 kevät-kesäkaudella. 
 Kastele vasta\, kun pintamulta (noin 2-3 cm) on kuivahtanut 
 kunnolla. Anna 
 mullan kuivua kastelujen välillä\, äläkä jätä sitä vettyneeksi. 
 VESIMÄÄRÄ: noin 0\,5-1\,5 dl per kastelukerran (mehikasvi).
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:rahapuu-syksy-talvi-1@sisakasvien-kastelukalenteri
DTSTAMP:20260503T090000Z
DTSTART;VALUE=DATE:20260101
RRULE:FREQ=MONTHLY;BYMONTH=1,2,3,10,11,12;BYMONTHDAY=1
SUMMARY:Rahapuu (Crassula ovata) - kastelun tarkistus (harvemmin)
DESCRIPTION:Tarkista kastelutarve kerran kuukaudessa syksy-talvikaudella. 
 Anna mullan kuivua kastelujen välissä tavallista enemmän ja kastele 
 niukasti.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:rahapuu-lannoitus-1@sisakasvien-kastelukalenteri
DTSTAMP:20260503T090000Z
DTSTART;VALUE=DATE:20260401
RRULE:FREQ=MONTHLY;INTERVAL=3;BYMONTH=4,5,6,7,8;BYMONTHDAY=1
SUMMARY:Rahapuu (Crassula ovata) - mieto lannoitus
DESCRIPTION:Lannoita rahapuuta kasvukaudella harvakseltaan\, noin 3-4 
 kuukauden välein. Nestemäinen huonekasvilannoite sopii\, kun annostus 
 pidetään miedohkona. Esimerkkituote: Substral Kaktus- ja 
 mehikasviravinne.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:sutipuu-kevat-kesa-1@sisakasvien-kastelukalenteri
DTSTAMP:20260503T090000Z
DTSTART;VALUE=DATE:20260401
RRULE:FREQ=WEEKLY;BYMONTH=4,5,6,7,8,9;BYDAY=MO,TH
SUMMARY:Sutipuu (Pachira aquatica) - kastelun tarkistus
DESCRIPTION:Tarkista kastelutarve kahdesti viikossa kevät-kesäkaudella 
 (PIENI RUUKKU). Pidä multa kosteahkona mutta hyvin vettä 
 läpäisevänä\, ja kastele kun pintamulta on kuivahtanut. Pienessä 
 ruukussa multa kuivuu nopeammin. Älä jätä vettä seisomaan 
 aluslautaselle. VESIMÄÄRÄ: noin 0\,5-1 dl per kastelukerran (pieni 
 ruukku).
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:sutipuu-syksy-talvi-1@sisakasvien-kastelukalenteri
DTSTAMP:20260503T090000Z
DTSTART;VALUE=DATE:20260101
RRULE:FREQ=WEEKLY;INTERVAL=2;BYMONTH=1,2,3,10,11,12
SUMMARY:Sutipuu (Pachira aquatica) - kastelun tarkistus (harvemmin)
DESCRIPTION:Tarkista kastelutarve noin kahden viikon välein 
 syksy-talvikaudella. Kastele talvella harvemmin\, mutta älä pidä 
 multaa 
 jatkuvasti märkänä tai vetisenä. Vältä jatkuvaa märkyyttä.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:sutipuu-lannoitus-1@sisakasvien-kastelukalenteri
DTSTAMP:20260503T090000Z
DTSTART;VALUE=DATE:20260501
RRULE:FREQ=MONTHLY;BYMONTH=5,6,7;BYMONTHDAY=1
SUMMARY:Sutipuu (Pachira aquatica) - mieto lannoitus
DESCRIPTION:Lannoita touko-heinäkuussa noin kerran kuukaudessa miedolla 
 annoksella. Sutipuu tarvitsee vähemmän lannoitusta kuin monet muut 
 kasvit. Esimerkkituote: Substral Viherravinne.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:kiiltojukka-kevat-kesa-1@sisakasvien-kastelukalenteri
DTSTAMP:20260508T090000Z
DTSTART;VALUE=DATE:20260401
RRULE:FREQ=WEEKLY;BYMONTH=4,5,6,7,8,9
SUMMARY:Kiiltojukka (Yucca gigantea) - kastelun tarkistus
DESCRIPTION:Tarkista kastelutarve viikoittain kevät-kesäkaudella 
 (PIENI RUUKKU - tarkista useammin tarvittaessa). Kastele vasta\, 
 kun mullan pinta (noin 2-3 cm pienessä ruukussa) on kuiva. Kastele 
 sitten kunnolla ja valuta ylimääräinen vesi pois. VESIMÄÄRÄ: noin 
 0\,3-0\,5 dl per kastelukerran (pieni ruukku\, kestää kuivuutta). 
 Ravinteet: lannoita miedosti kasvukaudella\, korkeintaan noin 
 kerran kuukaudessa. Esimerkkituote: Substral Viherravinne.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:kiiltojukka-syksy-talvi-1@sisakasvien-kastelukalenteri
DTSTAMP:20260508T090000Z
DTSTART;VALUE=DATE:20260101
RRULE:FREQ=WEEKLY;INTERVAL=2;BYMONTH=1,2,3,10,11,12
SUMMARY:Kiiltojukka (Yucca gigantea) - kastelun tarkistus (harvemmin)
DESCRIPTION:Tarkista kastelutarve noin kahden viikon välein 
 syksy-talvikaudella. Talvella kastele säästeliäästi vasta\, kun 
 mullan pinta (noin 5 cm) on kuiva.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:ronsylilja-kevat-kesa-1@sisakasvien-kastelukalenteri
DTSTAMP:20260508T090000Z
DTSTART;VALUE=DATE:20260401
RRULE:FREQ=WEEKLY;BYMONTH=4,5,6,7,8,9;BYDAY=MO,TH
SUMMARY:Rönsylilja (Chlorophytum comosum) - kastelun tarkistus
DESCRIPTION:Tarkista kastelutarve kahdesti viikossa kevät-kesäkaudella 
 (PIENI RUUKKU). Pidä multa kevyesti kosteana ja kastele\, kun 
 pintamulta (noin 1-2 cm) on kuivahtanut. Pienessä ruukussa multa 
 kuivuu nopeammin. VESIMÄÄRÄ: noin 0\,5-0\,8 dl per kastelukerran 
 (pieni ruukku). Ravinteet: käytä vesiliukoista tai hidasliukoista 
 huonekasvilannoitetta aktiivisen kasvun aikana valmistajan 
 annostusohjeen mukaan. Esimerkkituote: Substral Viherravinne.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:ronsylilja-syksy-talvi-1@sisakasvien-kastelukalenteri
DTSTAMP:20260508T090000Z
DTSTART;VALUE=DATE:20260101
RRULE:FREQ=WEEKLY;INTERVAL=2;BYMONTH=1,2,3,10,11,12
SUMMARY:Rönsylilja (Chlorophytum comosum) - kastelun tarkistus (harvemmin)
DESCRIPTION:Tarkista kastelutarve noin kahden viikon välein 
 syksy-talvikaudella. Kastele talvella harvemmin ja anna pintamullan 
 kuivahtaa kastelujen välillä.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:kirjovehka-kevat-kesa-1@sisakasvien-kastelukalenteri
DTSTAMP:20260508T090000Z
DTSTART;VALUE=DATE:20260401
RRULE:FREQ=WEEKLY;BYMONTH=4,5,6,7,8,9;BYDAY=MO,TH
SUMMARY:Kirjovehka (Dieffenbachia seguine) - kastelun tarkistus
DESCRIPTION:Tarkista kastelutarve kahdesti viikossa kevät-kesäkaudella 
 (PIENI RUUKKU). Kastele läpikotaisin ja anna pintamullan (noin 1-2 
 cm pienessä ruukussa) kuivua ennen seuraavaa kastelua. Älä jätä 
 vettä seisomaan aluslautaselle. Pienessä ruukussa multa kuivuu 
 nopeammin. VESIMÄÄRÄ: noin 0\,5-1 dl per kastelukerran (pieni 
 ruukku). Ravinteet: maalis-syyskuussa nestemäinen 
 viherkasvilannoite puolikkaalla vahvuudella 2-4 viikon välein. 
 Esimerkkituote: Substral Viherravinne.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

BEGIN:VEVENT
UID:kirjovehka-syksy-talvi-1@sisakasvien-kastelukalenteri
DTSTAMP:20260508T090000Z
DTSTART;VALUE=DATE:20260101
RRULE:FREQ=WEEKLY;INTERVAL=2;BYMONTH=1,2,3,10,11,12
SUMMARY:Kirjovehka (Dieffenbachia seguine) - kastelun tarkistus (harvemmin)
DESCRIPTION:Tarkista kastelutarve noin kahden viikon välein 
 syksy-talvikaudella. Kastele talvella harvemmin\, ja anna pintamullan 
 (noin 2-3 cm) kuivua ennen kastelua. Vältä jatkuvaa märkyyttä.
 Lähde: NC State Plant Toolbox; Clemson HGIC.
END:VEVENT

